# Auto-detect text files and normalize line endings
* text=auto

# PowerShell scripts should always use CRLF on checkout for Windows tooling
*.ps1    text eol=crlf
*.psm1   text eol=crlf
*.psd1   text eol=crlf

# C# / project files
*.cs     text eol=crlf
*.csproj text eol=crlf
*.sln    text eol=crlf

# YAML / Markdown can stay LF for cross-platform CI
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf

# Binary
*.dll binary
*.pdb binary
*.wim binary
*.zip binary
